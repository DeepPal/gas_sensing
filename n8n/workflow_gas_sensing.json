          }
        ],
        [
          {
            "node": "Notify Slack (Failure)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Get Full Results": {
      "main": [
        [
          {
            "node": "Notify Slack (Success)",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Notify Slack (Success)": {
      "main": [
        [
          {
            "node": "Check Sensor Health",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Check Sensor Health": {
      "main": [
        [
          {
            "node": "Run Health Check",
            "type": "main",
            "index": 0
          }
        ],
        []
      ]
    },
    "Run Health Check": {
      "main": [
        [
          {
            "node": "Alert Health Issue",
            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Scheduled Check": {
      "main": [
        [
          {
            "node": "Get Next Experiment",
            "type": "main",
