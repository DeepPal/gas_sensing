# =============================================================================
# Project-specific generated outputs
# These directories can grow very large (raw spectra at 20 Hz for hours).
# Keep the directory skeletons but ignore contents.
# =============================================================================

# Session recordings & model artefacts — large, regenerable
output/sessions/
output/models/
output/batch/
output/ethanol_ui/
output/ml_dataset/
output/calibration_memory_*.json
output/performance_summary_*.json
output/summary_*.json
output/test-history/
output/test-results/*.md
output/test-results/*.xml
output/memory/*.json
# Keep directory skeletons for Docker bind-mount compatibility (fresh clones)
!output/.gitkeep
!output/test-reports/.gitkeep

# Guardrail: block accidental flattened absolute-path artifacts
UsersdeeppDesktopChula_WorkPRojectsMain_Research_Chula*
cUsersdeeppDesktopChula_WorkPRojectsMain_Research_Chula*

# Generated reports & plots (regenerated by pipeline runs)
reports/plots/
reports/metrics/
reports/*.html
reports/*.pdf

# Logs
logs/
*.log

# Data directory (raw experimental CSVs — tracked separately or via DVC)
data/

