# =============================================================================
models/registry/*.pt
models/registry/*.joblib
models/registry/*.onnx
models/registry/calibration_params.json

# =============================================================================
# Processed data (regenerated from raw)
# =============================================================================
data/processed/

# Keep skeleton directories
!data/.gitkeep
!experiments/.gitkeep
!models/registry/.gitkeep

