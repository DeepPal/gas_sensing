    "/api/reports/generate": {
      "post": {
        "description": "Generate a scientist-facing session report.\n\nReturns ``{\"report\": \"<text>\", \"session_id\": \"<id>\"}`` on success.\nPrefers ``ReportWriter`` when available, but falls back to a deterministic\nscientific summary so researchers still get a useful report offline.",
        "operationId": "reports_generate_api_reports_generate_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ReportRequest"
              }
            }
