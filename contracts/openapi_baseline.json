{
  "components": {
    "schemas": {
      "AcquisitionConfig": {
        "properties": {
          "gas_label": {
            "default": "unknown",
            "title": "Gas Label",
            "type": "string"
          },
          "humidity_pct": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Humidity Pct"
          },
          "integration_time_ms": {
            "default": 50.0,
            "title": "Integration Time Ms",
            "type": "number"
          },
          "target_concentration": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Target Concentration"
          },
          "temperature_c": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Temperature C"
          }
        },
        "title": "AcquisitionConfig",
        "type": "object"
      },
      "AgentSettings": {
        "properties": {
          "auto_explain": {
            "title": "Auto Explain",
            "type": "boolean"
          }
        },
        "required": [
          "auto_explain"
        ],
        "title": "AgentSettings",
        "type": "object"
      },
      "AskRequest": {
        "properties": {
          "query": {
            "maxLength": 2000,
            "title": "Query",
            "type": "string"
          }
        },
        "required": [
          "query"
        ],
        "title": "AskRequest",
        "type": "object"
      },
      "CalibrationPoint": {
        "properties": {
          "concentration": {
            "title": "Concentration",
            "type": "number"
          },
          "delta_lambda": {
            "title": "Delta Lambda",
            "type": "number"
          }
        },
        "required": [
          "concentration",
          "delta_lambda"
        ],
        "title": "CalibrationPoint",
        "type": "object"
      },
      "DriftSettings": {
        "properties": {
          "drift_threshold_nm_per_min": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Drift Threshold Nm Per Min"
          },
          "window_frames": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Window Frames"
          }
        },
        "title": "DriftSettings",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "MixtureInferenceRequest": {
        "description": "Estimate analyte concentrations from observed peak shifts.",
        "properties": {
          "Kd_matrix": {
            "anyOf": [
              {
                "items": {
                  "items": {
                    "type": "number"
                  },
                  "type": "array"
                },
                "type": "array"
              },
              {
                "type": "null"
              }
            ],
            "title": "Kd Matrix"
          },
          "S_matrix": {
            "items": {
              "items": {
                "type": "number"
              },
              "type": "array"
            },
            "title": "S Matrix",
            "type": "array"
          },
          "analytes": {
            "items": {
              "type": "string"
            },
            "title": "Analytes",
            "type": "array"
          },
          "delta_lambda": {
            "items": {
              "type": "number"
            },
            "title": "Delta Lambda",
            "type": "array"
          },
          "use_nonlinear": {
            "default": false,
            "title": "Use Nonlinear",
            "type": "boolean"
          }
        },
        "required": [
          "delta_lambda",
          "analytes",
          "S_matrix"
        ],
        "title": "MixtureInferenceRequest",
        "type": "object"
      },
      "QualitySettings": {
        "properties": {
          "saturation_threshold": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Saturation Threshold"
          },
          "snr_warn_threshold": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "title": "Snr Warn Threshold"
          }
        },
        "title": "QualitySettings",
        "type": "object"
      },
      "ReportRequest": {
        "properties": {
          "session_id": {
            "minLength": 1,
            "title": "Session Id",
            "type": "string"
          }
        },
        "required": [
          "session_id"
        ],
        "title": "ReportRequest",
        "type": "object"
      },
      "SensitivityFitRequest": {
        "description": "Fit sensitivity matrix from single-analyte calibration data.",
        "properties": {
          "analytes": {
            "items": {
              "type": "string"
            },
            "title": "Analytes",
            "type": "array"
          },
          "calibration_data": {
            "items": {
              "additionalProperties": true,
              "type": "object"
            },
            "title": "Calibration Data",
            "type": "array"
          },
          "n_peaks": {
            "title": "N Peaks",
            "type": "integer"
          }
        },
        "required": [
          "analytes",
          "n_peaks",
          "calibration_data"
        ],
        "title": "SensitivityFitRequest",
        "type": "object"
      },
      "SimGenerateRequest": {
        "description": "Generate a batch of synthetic spectra from the physics simulation.",
        "properties": {
          "analyte_name": {
            "default": "Gas",
            "title": "Analyte Name",
            "type": "string"
          },
          "concentrations": {
            "default": [
              0.1,
              0.5,
              1.0,
              2.0,
              5.0
            ],
            "items": {
              "type": "number"
            },
            "title": "Concentrations",
            "type": "array"
          },
          "fwhm_nm": {
            "default": 20.0,
            "title": "Fwhm Nm",
            "type": "number"
          },
          "kd_ppm": {
            "default": 100.0,
            "title": "Kd Ppm",
            "type": "number"
          },
          "n_sessions": {
            "default": 5,
            "title": "N Sessions",
            "type": "integer"
          },
          "peak_nm": {
            "default": 700.0,
            "title": "Peak Nm",
            "type": "number"
          },
          "random_seed": {
            "default": 42,
            "title": "Random Seed",
            "type": "integer"
          },
          "sensitivity_nm_per_ppm": {
            "default": -0.5,
            "title": "Sensitivity Nm Per Ppm",
            "type": "number"
          },
          "tau_s": {
            "default": 30.0,
            "title": "Tau S",
            "type": "number"
          },
          "wl_end": {
            "default": 900.0,
            "title": "Wl End",
            "type": "number"
          },
          "wl_start": {
            "default": 500.0,
            "title": "Wl Start",
            "type": "number"
          }
        },
        "title": "SimGenerateRequest",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      }
    }
  },
  "info": {
    "title": "SpectraAgent",
    "version": "1.0.0"
  },
